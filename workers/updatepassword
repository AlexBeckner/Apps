#!/usr/bin/env bash
# Set the shared ACCESS_PASSWORD secret on every Worker in this folder.
#
#   cd Apps/workers && ./updatepassword
#
# Discovers Workers automatically (any subfolder containing a wrangler config),
# prompts for the password once, and pushes it to each Worker via wrangler.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

workers=()
for dir in */; do
  if [[ -f "${dir}wrangler.toml" || -f "${dir}wrangler.jsonc" || -f "${dir}wrangler.json" ]]; then
    workers+=("${dir%/}")
  fi
done

if [[ ${#workers[@]} -eq 0 ]]; then
  echo "No Workers found in $SCRIPT_DIR" >&2
  exit 1
fi

echo "Workers to update (ACCESS_PASSWORD):"
printf '  - %s\n' "${workers[@]}"
echo

read -rsp "New ACCESS_PASSWORD: " PW; echo
if [[ -z "$PW" ]]; then
  echo "Password cannot be empty." >&2
  exit 1
fi
read -rsp "Confirm ACCESS_PASSWORD: " PW2; echo
if [[ "$PW" != "$PW2" ]]; then
  echo "Passwords do not match." >&2
  exit 1
fi
unset PW2

read -rp "Set this password on ${#workers[@]} Worker(s)? [y/N] " ok
if [[ ! "$ok" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

fail=0
for w in "${workers[@]}"; do
  echo "-> $w"
  # printf '%s' avoids piping a trailing newline into the secret value.
  if ! ( cd "$w" && printf '%s' "$PW" | npx wrangler secret put ACCESS_PASSWORD ); then
    echo "  FAILED: $w" >&2
    fail=1
  fi
done
unset PW

if [[ $fail -ne 0 ]]; then
  echo "Done with errors -- see above." >&2
  exit 1
fi
echo "ACCESS_PASSWORD updated on all Workers."
